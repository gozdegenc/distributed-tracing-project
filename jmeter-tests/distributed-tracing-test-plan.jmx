            <stringProp name="script">
synchronized(props) {
    props.put("h_notif_ok",   ((props.get("h_notif_ok")   ?: 0) as Integer) + (prev.isSuccessful() ? 1 : 0))
    props.put("h_notif_fail", ((props.get("h_notif_fail") ?: 0) as Integer) + (prev.isSuccessful() ? 0 : 1))
}
            </stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>

        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler"
                       testname="T6 Uptime Report" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
def checks = [
    "gateway":   ["h_gateway_ok",   "h_gateway_fail"],
    "order":     ["h_order_ok",     "h_order_fail"],
    "inventory": ["h_inventory_ok", "h_inventory_fail"],
    "notif":     ["h_notif_ok",     "h_notif_fail"]
]
def totalOk = 0; def totalFail = 0
def sb = new StringBuilder("UPTIME_REPORT")

checks.each { name, keys ->
    def ok   = (props.get(keys[0]) ?: 0) as int
    def fail = (props.get(keys[1]) ?: 0) as int
    def t    = ok + fail
    def pct  = t > 0 ? (ok / t.toDouble()) * 100 : 100.0
    sb.append(" | " + name + "=" + String.format("%.1f", pct) + "%")
    totalOk += ok; totalFail += fail
}

def grand   = totalOk + totalFail
def overall = grand > 0 ? (totalOk / grand.toDouble()) * 100 : 100.0
sb.append(" | overall=" + String.format("%.2f", overall) + "% (" + totalOk + "/" + grand + " checks)")
log.info(sb.toString())
vars.put("uptime_percent", String.format("%.2f", overall))

SampleResult.setResponseData(sb.toString().getBytes("UTF-8"), "UTF-8")
SampleResult.setSuccessful(true)
SampleResult.setResponseCode("200")
SampleResult.setResponseMessage("OK")
          </stringProp>
        </JSR223Sampler>
        <hashTree/>

